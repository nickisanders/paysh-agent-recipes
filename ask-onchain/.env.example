# Copy to `.env` and fill in your values:  cp .env.example .env

# --- What to ask ---
QUESTION=Is the token at 0x1111111111111111111111111111111111111111 safe to buy?
CHAIN=ethereum

# --- Delivery: stdout | telegram | webhook | websocket ---
ALERT_SINK=stdout

# telegram sink (create a bot via @BotFather, get your id via @userinfobot):
# TELEGRAM_BOT_TOKEN=123456:ABC-DEF_your_bot_token
# TELEGRAM_CHAT_ID=123456789

# webhook sink — POSTs the JSON payload (question, tool, data, answer) to this URL:
# WEBHOOK_URL=https://your-service.example.com/ask

# websocket sink — pushes the JSON payload to this WS URL (needs `websocat`):
# WS_URL=ws://localhost:8080

# --- pay.sh endpoints the agent can reach (optional; override any that differ) ---
# PAYSH_AUDIT_URL=https://audit.pay.sh/contract
# PAYSH_MARKET_URL=https://market.pay.sh/price
# PAYSH_WALLET_URL=https://wallet.pay.sh/holdings
# PAYSH_RPC_URL=https://rpc.pay.sh/eth
# PAYSH_SEARCH_URL=https://search.pay.sh/answer
