# Copy to `.env` and source it, or set these inline in front of an action.

# Ask for approval when an action is worth at least this much (USD).
APPROVE_OVER_USD=25

# How to ask: terminal (y/N prompt) or telegram (message + reply).
APPROVE_CHANNEL=terminal

# telegram channel: seconds to wait for a reply before denying.
# APPROVE_TIMEOUT=300
# TELEGRAM_BOT_TOKEN=123456:ABC-DEF_your_bot_token
# TELEGRAM_CHAT_ID=123456789
