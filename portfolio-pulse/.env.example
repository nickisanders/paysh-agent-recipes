# Copy to `.env` and fill in your values:  cp .env.example .env

# --- Whose portfolio ---
WALLET=0xd8dA6BF26964aF9D7eEd9e03E53415D37aA96045
CHAIN=ethereum
# TOP=5                  # how many holdings to list

# --- Delivery: stdout | telegram | webhook | websocket ---
ALERT_SINK=stdout

# telegram sink (create a bot via @BotFather, get your id via @userinfobot):
# TELEGRAM_BOT_TOKEN=123456:ABC-DEF_your_bot_token
# TELEGRAM_CHAT_ID=123456789

# webhook sink — POSTs the JSON payload to this URL:
# WEBHOOK_URL=https://your-service.example.com/portfolio

# websocket sink — pushes the JSON payload to this WS URL (needs `websocat`):
# WS_URL=ws://localhost:8080

# --- pay.sh wallet-holdings endpoint (optional; override if your route differs) ---
# PAYSH_WALLET_URL=https://wallet.pay.sh/holdings
