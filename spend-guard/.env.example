# Copy to `.env` and source it, or set these inline in front of a call.

# Max total spend per day (USD).
GUARD_DAILY_CAP_USD=1.00

# Max spend on a single call (USD).
GUARD_CALL_MAX_USD=0.10

# Assumed cost of a call, used for accounting against the caps (USD).
GUARD_CALL_USD=0.005

# Only allow calls to these hosts (space or comma separated). Empty = allow all.
# GUARD_ALLOW_HOSTS=audit.pay.sh market.pay.sh search.pay.sh

# Where the daily ledger lives.
# GUARD_STATE_DIR=~/.spend-guard
