# Copy to `.env` and fill in your values:  cp .env.example .env

# --- Who to research ---
DOMAIN=stripe.com

# --- Delivery: stdout | telegram | webhook | websocket ---
ALERT_SINK=stdout

# telegram sink (create a bot via @BotFather, get your id via @userinfobot):
# TELEGRAM_BOT_TOKEN=123456:ABC-DEF_your_bot_token
# TELEGRAM_CHAT_ID=123456789

# webhook sink — POSTs the JSON payload (enrichment + news + brief) to this URL:
# WEBHOOK_URL=https://your-service.example.com/dossier

# websocket sink — pushes the JSON payload to this WS URL (needs `websocat`):
# WS_URL=ws://localhost:8080

# --- pay.sh endpoints (optional; override any whose route differs) ---
# PAYSH_ENRICH_URL=https://enrich.pay.sh/lookup
# PAYSH_SEARCH_URL=https://search.pay.sh/answer
