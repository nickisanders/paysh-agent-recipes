# Copy to `.env` and fill in your values:  cp .env.example .env

# --- What to brief on ---
# Topics or questions, comma separated. One web search per topic.
TOPICS=AI agent payments, Solana ecosystem, x402 protocol

# Optional: heading + email subject.
# BRIEF_TITLE=My Morning Brief

# --- Delivery: email | stdout | webhook | telegram ---
ALERT_SINK=email

# email sink — sent from a pay.sh agent inbox:
EMAIL_TO=you@example.com

# webhook sink — POSTs the JSON payload to this URL:
# WEBHOOK_URL=https://your-service.example.com/brief

# telegram sink (create a bot via @BotFather, get your id via @userinfobot):
# TELEGRAM_BOT_TOKEN=123456:ABC-DEF_your_bot_token
# TELEGRAM_CHAT_ID=123456789

# --- pay.sh endpoints (optional; override only if your routes differ) ---
# PAYSH_SEARCH_URL=https://search.pay.sh/answer
# PAYSH_EMAIL_URL=https://email.pay.sh/send
