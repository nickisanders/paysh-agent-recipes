# Copy to `.env` and fill in your values:  cp .env.example .env

# --- What to audit ---
ADDRESS=0x0000000000000000000000000000000000000000
CHAIN=ethereum

# Add a plain-English risk brief via pay claude (1 = on).
SUMMARIZE=1

# --- Delivery: stdout | telegram | webhook | websocket ---
ALERT_SINK=stdout

# telegram sink (create a bot via @BotFather, get your id via @userinfobot):
# TELEGRAM_BOT_TOKEN=123456:ABC-DEF_your_bot_token
# TELEGRAM_CHAT_ID=123456789

# webhook sink — POSTs the JSON payload to this URL:
# WEBHOOK_URL=https://your-service.example.com/audit

# websocket sink — pushes the JSON payload to this WS URL (needs `websocat`):
# WS_URL=ws://localhost:8080

# --- pay.sh audit endpoint (optional; override if your route differs) ---
# PAYSH_AUDIT_URL=https://audit.pay.sh/contract
