# Copy to `.env` and fill in your values:  cp .env.example .env

# --- What to watch ---
WATCH_URL=https://example.com/pricing

# Optional: summarize each change in plain English via `pay claude`
# (one extra paid call, only when a change is detected).
# SUMMARIZE=1

# Optional: extended-regex of lines to ignore, so rotating timestamps / nonces
# don't trigger false alerts.
# IGNORE_PATTERN=(Last updated|csrf-token|"nonce")

# --- pay.sh scrape endpoint (optional) ---
# Returns the page as markdown. Override only if your route differs.
# PAYSH_SCRAPE_URL=https://scrape.pay.sh/markdown

# --- Alert transport: telegram | webhook | websocket | stdout ---
ALERT_SINK=telegram

# telegram sink (create a bot via @BotFather, get your id via @userinfobot):
TELEGRAM_BOT_TOKEN=123456:ABC-DEF_your_bot_token
TELEGRAM_CHAT_ID=123456789

# webhook sink — POSTs the JSON payload to this URL:
# WEBHOOK_URL=https://your-service.example.com/page-change

# websocket sink — pushes the JSON payload to this WS URL (needs `websocat`):
# WS_URL=ws://localhost:8080

# stdout sink needs nothing — the JSON payload is printed for you to pipe.
