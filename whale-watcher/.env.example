# Copy to `.env` and fill in your values:  cp .env.example .env
# The example runner and cron setup both source this file.

# --- Twilio (https://console.twilio.com) ---
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_FROM=+14155550100        # your Twilio number, E.164
ALERT_TO=+14155550123           # where alerts are texted, E.164

# --- What to watch ---
WATCH_WALLET=0xd8dA6BF26964aF9D7eEd9e03E53415D37aA96045
THRESHOLD_USD=50000             # minimum transfer size (USD) that triggers an alert
