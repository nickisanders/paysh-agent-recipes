# Copy to `.env` and fill in your values:  cp .env.example .env

# --- What to extract ---
URL=https://example.com/product
FIELDS=name,price,in_stock,rating    # the fields you want back
# OUTPUT=./out.json                  # default: print to stdout

# --- pay.sh extract endpoint (optional; override if your route differs) ---
# PAYSH_EXTRACT_URL=https://extract.pay.sh/fields
