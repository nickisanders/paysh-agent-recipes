# Copy to `.env` and fill in your values:  cp .env.example .env

# --- pay.sh JSON-RPC endpoint for the chain you're watching ---
# The pay.sh directory lists per-request RPC routes for 140+ networks.
PAYSH_RPC_URL=https://rpc.pay.sh/eth   # example; use the route for your chain

# --- Alert transport: telegram | webhook | websocket | stdout ---
ALERT_SINK=telegram

# telegram sink (create a bot via @BotFather, get your id via @userinfobot):
TELEGRAM_BOT_TOKEN=123456:ABC-DEF_your_bot_token
TELEGRAM_CHAT_ID=123456789

# webhook sink — POSTs the JSON payload to this URL:
# WEBHOOK_URL=https://your-service.example.com/whale

# websocket sink — pushes the JSON payload to this WS URL (needs `websocat`):
# WS_URL=ws://localhost:8080

# stdout sink needs nothing — the JSON payload is printed for you to pipe.

# --- What to watch ---
WATCH_WALLET=0xd8dA6BF26964aF9D7eEd9e03E53415D37aA96045
THRESHOLD_NATIVE=100        # min transfer size in the chain's native unit
NATIVE_SYMBOL=ETH           # display symbol for that unit
POLL_SECONDS=3              # how often to check for a new block
